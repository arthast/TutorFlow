TUTORFLOW_DOMAIN=netwatch-arsen-demo.ru
CADDY_EMAIL=admin@netwatch-arsen-demo.ru
TUTORFLOW_IMAGE_NAMESPACE=ghcr.io/arthast
IMAGE_TAG=latest

POSTGRES_USER=tutorflow
POSTGRES_PASSWORD=change_me_to_random_value

JWT_SECRET=change_me_to_long_random_value
JWT_TTL_SECONDS=86400

GATEWAY_CORS_ORIGIN=https://netwatch-arsen-demo.ru

ASSIGNMENT_DEADLINE_WORKER_PERIOD_MS=60000

FILE_STORAGE_BACKEND=s3
FILE_STORAGE_DIR=/data/files
FILE_MAX_SIZE_BYTES=10485760

MINIO_ROOT_USER=tutorflow
MINIO_ROOT_PASSWORD=change_me_to_random_value
FILE_S3_ENDPOINT=http://minio:9000
FILE_S3_BUCKET=tutorflow-files
FILE_S3_REGION=us-east-1

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=tutorflow-admin
GRAFANA_ADMIN_PASSWORD=change_me_to_long_random_value
