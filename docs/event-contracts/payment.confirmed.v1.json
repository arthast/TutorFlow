{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "payment.confirmed.v1",
  "description": "Преподаватель подтвердил чек оплаты ученика; создан payment, баланс уменьшен. Consumer'ы (notification/report на 5G) уведомляют ученика / агрегируют финансы. Payload самодостаточен.",
  "topic": "tutorflow.payment.confirmed",
  "key": "receipt_id",
  "producer": "finance-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "payment.confirmed" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["receipt_id", "payment_id", "teacher_id", "student_id", "amount", "currency", "confirmed_at"],
      "properties": {
        "receipt_id": { "type": "string", "format": "uuid" },
        "payment_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "confirmed_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "f0e1d2c3-b4a5-4968-8776-554433221100",
    "event_type": "payment.confirmed",
    "event_version": 1,
    "occurred_at": "2026-06-24T10:10:00Z",
    "producer": "finance-service",
    "trace_id": "req-ghi789",
    "payload": {
      "receipt_id": "55555555-5555-5555-5555-555555555555",
      "payment_id": "66666666-6666-6666-6666-666666666666",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "amount": 1500.0,
      "currency": "RUB",
      "confirmed_at": "2026-06-24T10:10:00Z"
    }
  }
}
