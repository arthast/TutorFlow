{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assignment.reviewed.v1",
  "description": "Преподаватель проверил последнее решение ДЗ. Consumer'ы notification/report уведомляют ученика и обновляют статусы.",
  "topic": "tutorflow.assignment.reviewed",
  "key": "assignment_id",
  "producer": "assignment-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "assignment.reviewed" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "assignment-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["assignment_id", "submission_id", "teacher_id", "student_id", "review_status", "assignment_status", "reviewed_at"],
      "properties": {
        "assignment_id": { "type": "string", "format": "uuid" },
        "submission_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "review_status": { "enum": ["reviewed", "needs_fix", "accepted"] },
        "assignment_status": { "enum": ["reviewed", "needs_fix", "done"] },
        "comment": { "type": ["string", "null"] },
        "reviewed_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
