{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lesson.cancelled.v1",
  "description": "Занятие отменено. previous_status показывает, из какого состояния отменили: 'scheduled' — финансовых последствий нет; 'completed' — за занятие был создан charge, и finance ОБЯЗАН добавить компенсирующую correction на сумму charge, ИДЕМПОТЕНТНО по lesson_id (charge не удаляется — append-only). Поля price/currency заполняются ТОЛЬКО при previous_status='completed' (нужны для компенсации). Consumers: finance-service (компенсация при previous_status='completed'), notification-service, report-service.",
  "topic": "tutorflow.lesson.cancelled",
  "key": "lesson_id",
  "producer": "lesson-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "lesson.cancelled" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "lesson-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["lesson_id", "teacher_id", "student_id", "previous_status", "cancelled_at"],
      "properties": {
        "lesson_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "previous_status": { "enum": ["scheduled", "completed"] },
        "price": { "type": ["number", "null"], "exclusiveMinimum": 0, "description": "Заполнено только при previous_status='completed' (сумма для компенсирующей correction)." },
        "currency": { "type": ["string", "null"], "examples": ["RUB"] },
        "cancelled_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "4c3d0c2e-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "lesson.cancelled",
    "event_version": 1,
    "occurred_at": "2026-06-24T10:05:00Z",
    "producer": "lesson-service",
    "trace_id": "req-def456",
    "payload": {
      "lesson_id": "11111111-1111-1111-1111-111111111111",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "previous_status": "completed",
      "price": 1500.0,
      "currency": "RUB",
      "cancelled_at": "2026-06-24T10:04:30Z"
    }
  }
}
