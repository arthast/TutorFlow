{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "charge.created.v1",
  "description": "finance-service создал charge transaction из lesson.completed. Источник истины остаётся append-only ledger.",
  "topic": "tutorflow.charge.created",
  "key": "transaction_id",
  "producer": "finance-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "charge.created" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "finance-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["transaction_id", "teacher_id", "student_id", "lesson_id", "amount", "currency", "created_at"],
      "properties": {
        "transaction_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "lesson_id": { "type": "string", "format": "uuid" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
