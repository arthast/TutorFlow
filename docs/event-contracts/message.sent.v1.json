{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "message.sent.v1",
  "description": "В диалоге отправлено новое сообщение (chat-service, через outbox). Consumers: notification-service (уведомить получателя recipient_id), report-service позже. Payload самодостаточен; текст сообщения целиком НЕ кладём — только опциональный короткий preview.",
  "topic": "tutorflow.message.sent",
  "key": "dialog_id",
  "producer": "chat-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "message.sent" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "chat-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["dialog_id", "message_id", "sender_id", "recipient_id", "teacher_id", "student_id", "has_attachments", "sent_at"],
      "properties": {
        "dialog_id": { "type": "string", "format": "uuid" },
        "message_id": { "type": "string", "format": "uuid" },
        "sender_id": { "type": "string", "format": "uuid" },
        "recipient_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "has_attachments": { "type": "boolean" },
        "preview": { "type": ["string", "null"], "description": "Короткий обрезанный текст для уведомления (опционально); полный текст не передаём." },
        "sent_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "a1b2c3d4-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "message.sent",
    "event_version": 1,
    "occurred_at": "2026-06-26T13:00:00Z",
    "producer": "chat-service",
    "trace_id": "req-chat-1",
    "payload": {
      "dialog_id": "dddddddd-dddd-dddd-dddd-dddddddddddd",
      "message_id": "mmmmmmmm-mmmm-mmmm-mmmm-mmmmmmmmmmmm",
      "sender_id": "22222222-2222-2222-2222-222222222222",
      "recipient_id": "33333333-3333-3333-3333-333333333333",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "has_attachments": false,
      "preview": "Привет! Не забудь про домашку",
      "sent_at": "2026-06-26T12:59:55Z"
    }
  }
}
