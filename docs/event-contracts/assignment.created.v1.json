{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assignment.created.v1",
  "description": "Преподаватель создал домашнее задание. Потенциальные consumer'ы (notification/report на 5G) уведомляют ученика / строят прогресс. Команды через Kafka НЕ шлём — это событие факта, не команда.",
  "topic": "tutorflow.assignment.created",
  "key": "assignment_id",
  "producer": "assignment-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "assignment.created" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["assignment_id", "teacher_id", "student_id", "title", "created_at"],
      "properties": {
        "assignment_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "due_at": { "type": ["string", "null"], "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
    "event_type": "assignment.created",
    "event_version": 1,
    "occurred_at": "2026-06-24T10:05:00Z",
    "producer": "assignment-service",
    "trace_id": "req-def456",
    "payload": {
      "assignment_id": "44444444-4444-4444-4444-444444444444",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "title": "Интегралы, лист 3",
      "due_at": "2026-06-30T20:00:00Z",
      "created_at": "2026-06-24T10:05:00Z"
    }
  }
}
