{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lesson.completed.v1",
  "description": "Преподаватель отметил занятие завершённым. Consumer (finance на 5E) создаёт charge ИДЕМПОТЕНТНО по lesson_id. Payload самодостаточен — finance НЕ ходит обратно в lesson.",
  "topic": "tutorflow.lesson.completed",
  "key": "lesson_id",
  "producer": "lesson-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "lesson.completed" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["lesson_id", "teacher_id", "student_id", "price", "currency", "completed_at"],
      "properties": {
        "lesson_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "price": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "7b3f0c2e-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "lesson.completed",
    "event_version": 1,
    "occurred_at": "2026-06-24T10:00:00Z",
    "producer": "lesson-service",
    "trace_id": "req-abc123",
    "payload": {
      "lesson_id": "11111111-1111-1111-1111-111111111111",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "price": 1500.0,
      "currency": "RUB",
      "completed_at": "2026-06-24T09:59:30Z"
    }
  }
}
