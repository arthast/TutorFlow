{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "payment_receipt.uploaded.v1",
  "description": "Ученик загрузил чек оплаты. Баланс не меняется до confirm; consumer'ы уведомляют преподавателя и строят отчёты.",
  "topic": "tutorflow.payment_receipt.uploaded",
  "key": "receipt_id",
  "producer": "finance-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "payment_receipt.uploaded" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "finance-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["receipt_id", "teacher_id", "student_id", "file_id", "amount", "currency", "status", "submitted_at"],
      "properties": {
        "receipt_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "file_id": { "type": "string", "format": "uuid" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "status": { "const": "pending_review" },
        "submitted_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
