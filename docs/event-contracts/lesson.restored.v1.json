{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lesson.restored.v1",
  "description": "Завершённое занятие, которое ранее отменили, восстановлено (reactivate: cancelled → completed). finance-consumer добавляет компенсирующую обратно correction(+price), ИДЕМПОТЕНТНО по event_id (атомарный inbox processed_events; charge не создаётся повторно — он один на занятие). Зеркало lesson.cancelled(previous_status=completed). Consumers: finance-service (восстановление долга), notification-service, report-service.",
  "topic": "tutorflow.lesson.restored",
  "key": "lesson_id",
  "producer": "lesson-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "lesson.restored" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "lesson-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["lesson_id", "teacher_id", "student_id", "price", "currency", "restored_at"],
      "properties": {
        "lesson_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "price": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "restored_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "6e5d0c2e-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "lesson.restored",
    "event_version": 1,
    "occurred_at": "2026-06-25T11:00:00Z",
    "producer": "lesson-service",
    "trace_id": "req-ghi789",
    "payload": {
      "lesson_id": "11111111-1111-1111-1111-111111111111",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "price": 2000.0,
      "currency": "RUB",
      "restored_at": "2026-06-25T10:59:30Z"
    }
  }
}
