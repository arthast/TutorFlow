{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lesson.scheduled.v1",
  "description": "Занятие стало запланированным. Эмитится при создании занятия (origin=created) и при восстановлении отменённого незавершённого занятия (origin=reactivated). Consumers: notification-service, report-service.",
  "topic": "tutorflow.lesson.scheduled",
  "key": "lesson_id",
  "producer": "lesson-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "lesson.scheduled" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "lesson-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["lesson_id", "teacher_id", "student_id", "starts_at", "ends_at", "scheduled_at"],
      "properties": {
        "lesson_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "starts_at": { "type": "string", "format": "date-time" },
        "ends_at": { "type": "string", "format": "date-time" },
        "scheduled_at": { "type": "string", "format": "date-time" },
        "origin": { "type": "string", "enum": ["created", "reactivated"] }
      }
    }
  },
  "example": {
    "event_id": "9a1f0c2e-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "lesson.scheduled",
    "event_version": 1,
    "occurred_at": "2026-06-24T10:00:00Z",
    "producer": "lesson-service",
    "trace_id": "req-abc123",
    "payload": {
      "lesson_id": "11111111-1111-1111-1111-111111111111",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "starts_at": "2026-06-25T09:00:00Z",
      "ends_at": "2026-06-25T10:00:00Z",
      "scheduled_at": "2026-06-24T09:59:30Z",
      "origin": "created"
    }
  }
}
