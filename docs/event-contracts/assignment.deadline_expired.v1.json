{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assignment.deadline_expired.v1",
  "description": "Дедлайн ДЗ истёк, и оно осталось невыполненным (статус ждал действий ученика) — deadline-worker перевёл его в 'expired' и опубликовал факт через outbox. Consumers: notification-service (уведомить ученика), report-service (статистика). previous_status — из какого статуса перевели.",
  "topic": "tutorflow.assignment.deadline_expired",
  "key": "assignment_id",
  "producer": "assignment-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "assignment.deadline_expired" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "assignment-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["assignment_id", "teacher_id", "student_id", "title", "due_at", "previous_status", "expired_at"],
      "properties": {
        "assignment_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "due_at": { "type": "string", "format": "date-time" },
        "previous_status": { "enum": ["assigned", "needs_fix"] },
        "expired_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "example": {
    "event_id": "c3d4e5f6-1a2b-4c3d-9e8f-0a1b2c3d4e5f",
    "event_type": "assignment.deadline_expired",
    "event_version": 1,
    "occurred_at": "2026-06-27T00:00:05Z",
    "producer": "assignment-service",
    "trace_id": "deadline-worker",
    "payload": {
      "assignment_id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
      "teacher_id": "22222222-2222-2222-2222-222222222222",
      "student_id": "33333333-3333-3333-3333-333333333333",
      "title": "Задача 5: интегралы",
      "due_at": "2026-06-26T23:59:00Z",
      "previous_status": "assigned",
      "expired_at": "2026-06-27T00:00:05Z"
    }
  }
}
