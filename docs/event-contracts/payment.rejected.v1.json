{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "payment.rejected.v1",
  "description": "Преподаватель отклонил чек оплаты. Payment transaction не создаётся; баланс не меняется.",
  "topic": "tutorflow.payment.rejected",
  "key": "receipt_id",
  "producer": "finance-service",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "payment.rejected" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "finance-service" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["receipt_id", "teacher_id", "student_id", "amount", "currency", "rejected_at"],
      "properties": {
        "receipt_id": { "type": "string", "format": "uuid" },
        "teacher_id": { "type": "string", "format": "uuid" },
        "student_id": { "type": "string", "format": "uuid" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "examples": ["RUB"] },
        "comment": { "type": ["string", "null"] },
        "rejected_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
