# Шаблон окружения для TutorFlow. Скопируй в .env и заполни.
# .env в git не коммитится (см. .gitignore).

# === PostgreSQL (один контейнер, отдельная БД на сервис) ===
POSTGRES_USER=tutorflow
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Отдельные БД на сервис
IDENTITY_DB=identity_db
LESSON_DB=lesson_db
ASSIGNMENT_DB=assignment_db
FINANCE_DB=finance_db
FILE_DB=file_db
NOTIFICATION_DB=notification_db
REPORT_DB=report_db
CHAT_DB=chat_db

# Полные connection-строки (формируются из значений выше)
IDENTITY_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/identity_db
LESSON_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/lesson_db
ASSIGNMENT_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/assignment_db
FINANCE_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/finance_db
FILE_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/file_db
NOTIFICATION_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/notification_db
REPORT_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/report_db
CHAT_DATABASE_URL=postgresql://tutorflow:change_me@postgres:5432/chat_db

# === Redis (realtime-service only; internal docker network) ===
REDIS_URL=redis://redis:6379

# === Auth ===
# Общий секрет: identity-service подписывает JWT, api-gateway валидирует им же.
JWT_SECRET=change_me_long_random_secret
JWT_TTL_SECONDS=86400

# === Порты сервисов (наружу: gateway 8080 и realtime WebSocket 8089) ===
GATEWAY_PORT=8080
IDENTITY_PORT=8081
LESSON_PORT=8082
ASSIGNMENT_PORT=8083
FINANCE_PORT=8084
FILE_PORT=8085
NOTIFICATION_PORT=8086
REPORT_PORT=8087
CHAT_PORT=8088
REALTIME_PORT=8089

# === api-gateway CORS ===
GATEWAY_CORS_ORIGIN=http://localhost:5173

# === file-service ===
FILE_STORAGE_BACKEND=local
FILE_STORAGE_DIR=/data/files
FILE_MAX_SIZE_BYTES=10485760

# === MinIO/S3 dev storage (used when FILE_STORAGE_BACKEND=s3) ===
MINIO_ROOT_USER=tutorflow
MINIO_ROOT_PASSWORD=tutorflow_minio_password
FILE_S3_ENDPOINT=http://minio:9000
FILE_S3_BUCKET=tutorflow-files
FILE_S3_REGION=us-east-1
